{
  "expo": {
    "name": "Nuti",
    "slug": "nuti",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#3BB273"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nuti.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#3BB273"
      },
      "package": "com.nuti.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {},
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Permitir acesso à câmera para tirar fotos de refeições."
        }
      ],
      [
        "expo-barcode-scanner",
        {
          "cameraPermission": "Permitir acesso à câmera para ler códigos de barras."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Permitir acesso às fotos para adicionar imagens de refeições."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#3BB273"
        }
      ],
      "expo-font",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 34,
            "targetSdkVersion": 34,
            "buildToolsVersion": "34.0.0",
            "kotlinVersion": "2.2.20"
          }
        }
      ]
    ],
    "updates": {
      "enabled": false,
      "fallbackToCacheTimeout": 0
    },
    "extra": {
      "eas": {
        "projectId": "c4b743aa-2dbe-48a5-9bb0-782620ac7a6e"
      }
    }
  }
}
