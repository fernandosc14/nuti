rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Regras para users
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Regras para meals
    match /meals/{mealId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    
    // Regras para messages
    match /messages/{messageId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      // Permitir update apenas para marcar como deletada (campo deleted)
      // Verificar que o utilizador é o dono, que deleted está a ser definido como true,
      // e que o userId não está a ser alterado
      allow update: if request.auth != null && 
                    request.auth.uid == resource.data.userId &&
                    request.resource.data.deleted == true &&
                    request.resource.data.userId == resource.data.userId;
      // Permitir delete para exclusão de conta
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    
    // Regras para badges (apenas leitura para utilizadores autenticados)
    match /badges/{badgeId} {
      allow read: if request.auth != null;
      // Temporariamente permitir criação para desenvolvimento
      // TODO: Mudar para "allow write: if false;" antes de produção
      allow write: if request.auth != null; // Temporário - permite criar badges durante desenvolvimento
    }
    
    // Regras para water (água bebida)
    match /water/{waterId} {
      // Simplificar regras para melhor performance
      // Formato do ID: userId_dateStr, então verificar diretamente
      allow read: if request.auth != null && (
        !resource.exists || 
        request.auth.uid == resource.data.userId ||
        request.auth.uid == waterId.split('_')[0]
      );
      allow create, update: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow delete: if request.auth != null && (
        (!resource.exists || request.auth.uid == resource.data.userId) ||
        request.auth.uid == waterId.split('_')[0]
      );
    }
    
    // Regras para customExerciseTypes (tipos de exercício customizados por usuário)
    match /customExerciseTypes/{typeId} {
      allow read: if request.auth != null && (
        !exists(/databases/$(database)/documents/customExerciseTypes/$(typeId)) ||
        request.auth.uid == resource.data.userId
      );
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null && request.auth.uid == resource.data.userId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    
    // Regras para exercises (exercícios físicos)
    match /exercises/{exerciseId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    
    // Regras para savedMeals (refeições guardadas)
    match /savedMeals/{savedMealId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    
    // Regras para steps (passos)
    match /steps/{stepId} {
      // Simplificar regras para melhor performance
      // Formato do ID: userId_dateStr, então verificar diretamente
      allow read: if request.auth != null && (
        !resource.exists || 
        request.auth.uid == resource.data.userId ||
        request.auth.uid == stepId.split('_')[0]
      );
      allow create, update: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow delete: if request.auth != null && (
        (!resource.exists || request.auth.uid == resource.data.userId) ||
        request.auth.uid == stepId.split('_')[0]
      );
    }
  }
}
